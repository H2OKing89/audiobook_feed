# AudioStacker Project - GitIgnore Configuration
# 
# This project includes:
# - Python backend (AudioStacker core)
# - Node.js/Express API server
# - Vue.js frontend application
# 
# Key files to track:
# ✅ All source code (.py, .js, .vue files in src/)
# ✅ Configuration files (package.json, babel.config.js, etc.)
# ✅ Documentation and README files
# 
# Key files to ignore:
# ❌ node_modules/, dist/, build/ directories
# ❌ Database files (*.db, *.sqlite)
# ❌ Log files and temporary files
# ❌ IDE and OS specific files
# ❌ Secret configuration files

# === Python ===
logs/
*.pyc
__pycache__/
.venv/
.pytest_cache/
*.egg-info/
dist/
build/

# === Node.js / JavaScript ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache

# === Frontend (Vue.js) ===
src/web/frontend/node_modules/
src/web/frontend/dist/
src/web/frontend/.cache/
src/web/frontend/.temp/
src/web/frontend/.nuxt/
src/web/frontend/.vuepress/dist

# === Backend (Node.js) ===
src/web/backend/node_modules/
src/web/backend/.env

# === Important: Include these JavaScript/Vue files ===
# All .js, .vue, .json, .ts files in src/ should be tracked
# !src/**/*.js
# !src/**/*.vue  
# !src/**/*.json
# !src/**/*.ts

# === Configuration & Secrets ===
config/*.secret.yaml
# Main .env files are tracked for development setup
# src/web/frontend/.env 
# src/web/backend/.env
# But local/production/test variants are not tracked
.env
*.env.local
*.env.production
*.env.test
audiobooks.yaml
config.yaml

# === Database Files ===
*.db
*.sqlite3
*.sqlite
*.db-wal
*.db-shm
*.db-journal
.last_vacuum

# === Logs ===
*.log
*.pid
logs/

# === Data & Cache ===
data/
cache/
tmp/
temp/

# === IDE & Editor ===
.vscode/
.idea/
*.swp
*.swo
*~

# === OS ===
.DS_Store
Thumbs.db

# === Testing ===
coverage/
.coverage
.nyc_output
test-results/

# === Temporary Files ===
debug_*.py
test_*.py
test_*.js
print_*.js
*.tmp

# === Project-specific Temporary Files ===
feeds.json

